rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite leitura e escrita pública para a coleção 'veiculos'
    // Nota: Em produção, configure regras adequadas para restringir a escrita ao administrador.
    match /veiculos/{veiculoId} {
      allow read, write: if true;
    }

    // Permite leitura e escrita para a coleção 'usuarios' se o usuário estiver autenticado e for dono do documento
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
